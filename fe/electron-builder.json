{
  "appId": "com.bluritout.app",
  "productName": "BlurItOut",
  "npmRebuild": false,
  "files": ["dist-react", "dist-electron", "src/electron/preload.cjs"],
  "extraResources": [
    {
      "from": "../engine/dist/worker",
      "to": "engine",
      "filter": ["**/*"]
    }
  ],
  "icon": "./winIcon.png",
  "mac": {
    "target": "dmg",
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg/ffmpeg"
      },
      {
        "from": "node_modules/ffprobe-static/bin/darwin/x64/ffprobe",
        "to": "ffmpeg/ffprobe"
      }
    ]
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg/ffmpeg"
      },
      {
        "from": "node_modules/ffprobe-static/bin/linux/x64/ffprobe",
        "to": "ffmpeg/ffprobe"
      }
    ]
  },
  "win": {
    "target": ["zip"],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg/ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "ffmpeg/ffprobe.exe"
      }
    ]
  }
}
