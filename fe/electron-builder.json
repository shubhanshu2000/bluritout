{
  "appId": "com.bluritout.app",
  "productName": "BlurItOut",
  "files": ["dist-react", "dist-electron", "src/electron/preload.cjs"],
  "extraResources": [
    {
      "from": "../engine/dist/worker",
      "to": "engine",
      "filter": ["**/*"]
    }
  ],
  "icon": "./build/icon",
  "mac": {
    "target": "dmg",
    "icon": "./build/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "icon": "./build/icon.png"
  },
  "win": {
    "target": ["portable", "msi"],
    "icon": "./build/icon.ico"
  }
}
