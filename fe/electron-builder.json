{
  "appId": "com.bluritout.app",
  "productName": "BlurItOut",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "npmRebuild": false,
  "files": ["dist-react", "dist-electron", "src/electron/preload.cjs"],
  "extraResources": [
    {
      "from": "../engine/dist/worker",
      "to": "engine",
      "filter": ["**/*"]
    }
  ],
  "icon": "./winIcon.png",
  "mac": {
    "target": "dmg",
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg/ffmpeg"
      },
      {
        "from": "node_modules/ffprobe-static/bin/darwin/x64/ffprobe",
        "to": "ffmpeg/ffprobe"
      }
    ]
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg/ffmpeg"
      },
      {
        "from": "node_modules/ffprobe-static/bin/linux/x64/ffprobe",
        "to": "ffmpeg/ffprobe"
      }
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg/ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "ffmpeg/ffprobe.exe"
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "BlurItOut"
  }
}
